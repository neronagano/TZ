LOG_LEVEL=INFO
LOG_FORMAT=console
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_URL=http://localhost:8000

POSTGRES_DB=server
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST_DOCKER=db
POSTGRES_PORT_DOCKER=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/server
CLIENT_API_URL=http://server:8000
CLIENT_WORKERS=5
CLIENT_MAX_DELAY_MS=1000
CLIENT_REQUESTS_PER_WORKER=10
CLIENT_LOG_FILE=client/logs/client.log
CLIENT_LOG_FILE_DOCKER=/app/client/logs/client.log
CLIENT_REQUEST_TIMEOUT_SECONDS=5
CLIENT_MAX_ATTEMPTS=3
CLIENT_RETRY_BACKOFF_MS=200
WORKER_API_URL=http://server:8000
WORKER_POLL_INTERVAL_SECONDS=5
WORKER_PAGE_SIZE=100
WORKER_OUTPUT_FILE=worker/data/log_entries.jsonl
WORKER_OUTPUT_FILE_DOCKER=/app/worker/data/log_entries.jsonl
